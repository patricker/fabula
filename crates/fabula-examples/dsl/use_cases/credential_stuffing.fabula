pattern credential_stuffing {
  stage e1 {
    e1.type = "failed_login"
    e1.account -> ?account
    e1.source -> ?src_a
  }
  stage e2 {
    e2.type = "failed_login"
    e2.account -> ?account
    e2.source -> ?src_b
  }
  unless between e1 e2 {
    mid.type = "successful_login"
    mid.account -> ?account
  }
}
